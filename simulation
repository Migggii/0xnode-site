        <div class="stat-card wide">
          <div class="stat-label">Status</div>
          <div class="stat-value" id="statusValue" style="font-size:20px;">Startphase aktiv</div>
          <div class="stat-sub" id="statusSub">
            Das Dashboard läuft automatisch und setzt sich nach Abschluss selbst zurück.
          </div>
