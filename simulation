        <div class="stat-card">
          <div class="stat-label">Reinvestiert</div>
          <div class="stat-value" id="reinvestValue">$0</div>
          <div class="stat-sub">zurück ins System</div>
        </div>

        <div class="stat-card">
          <div class="stat-label">Cashflow</div>
          <div class="stat-value" id="cashflowValue">$0</div>
          <div class="stat-sub">kleiner Teil separiert</div>
        </div>

        <div class="stat-card">
          <div class="stat-label">APR (simuliert)</div>
          <div class="stat-value" id="aprValue">5.2%</div>
