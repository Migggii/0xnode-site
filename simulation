      </div>
    </aside>
  </section>
</main>

<script>
const startValue = 500;
const targetValue = 15000;
const monthsTotal = 24;
const animationDuration = 12000;
const restartDelay = 2200;

const portfolioValueEl = document.getElementById("portfolioValue");
const portfolioGainEl = document.getElementById("portfolioGain");
const monthLabelEl = document.getElementById("monthLabel");
const rewardsValueEl = document.getElementById("rewardsValue");
const reinvestValueEl = document.getElementById("reinvestValue");
const cashflowValueEl = document.getElementById("cashflowValue");
const aprValueEl = document.getElementById("aprValue");
const feesValueEl = document.getElementById("feesValue");
const emissionsValueEl = document.getElementById("emissionsValue");
const chartHintEl = document.getElementById("chartHint");
const statusValueEl = document.getElementById("statusValue");
const statusSubEl = document.getElementById("statusSub");
const liveTextEl = document.getElementById("liveText");
const timelineTextEl = document.getElementById("timelineText");
const timelineProgressEl = document.getElementById("timelineProgress");
const phaseTextEl = document.getElementById("phaseText");
const loopCounterEl = document.getElementById("loopCounter");

const canvas = document.getElementById("chart");
const ctx = canvas.getContext("2d");

const points = {
  1: document.getElementById("point1"),
  6: document.getElementById("point6"),
  12: document.getElementById("point12"),
  18: document.getElementById("point18"),
  24: document.getElementById("point24")
};

let chartValues = [];
let animationFrameId = null;
let loopTimeout = null;
let loopCount = 1;

function formatUSD(value){
  return "$" + Math.round(value).toLocaleString("en-US");
}

function easeInOutCubic(x){
  return x < 0.5
    ? 4 * x * x * x
    : 1 - Math.pow(-2 * x + 2, 3) / 2;
}

function growthCurve(progress){
  const curved = Math.pow(progress, 1.65);
  return startValue + (targetValue - startValue) * curved;
}

function animateNumber(el, value, suffix = "", prefix = ""){
  el.textContent = prefix + value + suffix;
}

function updatePoints(month){
  Object.values(points).forEach(el => el.classList.remove("active"));

  if(month >= 24){
    points[24].classList.add("active");
    timelineTextEl.textContent = "Langfristiger Effekt sichtbar";
  }else if(month >= 18){
    points[18].classList.add("active");
    timelineTextEl.textContent = "Beschleunigungsphase aktiv";
  }else if(month >= 12){
    points[12].classList.add("active");
    timelineTextEl.textContent = "Reinvestition wirkt";
  }else if(month >= 6){
    points[6].classList.add("active");
    timelineTextEl.textContent = "Erste Dynamik sichtbar";
  }else{
    points[1].classList.add("active");
    timelineTextEl.textContent = "Startpunkt aktiv";
  }

  const percent = ((month - 1) / (monthsTotal - 1)) * 100;
  timelineProgressEl.style.width = percent + "%";
}

function updateHint(month){
  if(month < 6){
    chartHintEl.textContent = "Startphase";
    statusValueEl.textContent = "Startphase aktiv";
    statusSubEl.textContent = "Das Portfolio wächst noch ruhig. Die Bewegung ist bewusst am Anfang langsamer.";
    liveTextEl.textContent = "Zeitraffer läuft";
    phaseTextEl.textContent = "Start → Orientierung → ruhiger Aufbau";
  }else if(month < 12){
    chartHintEl.textContent = "erste Dynamik";
    statusValueEl.textContent = "Momentum nimmt zu";
    statusSubEl.textContent = "Erste Dynamik wird sichtbar. Rewards und Fees beginnen deutlicher zu steigen.";
    liveTextEl.textContent = "Dynamik steigt";
    phaseTextEl.textContent = "Wachstum → erste Dynamik → System reagiert";
  }else if(month < 18){
    chartHintEl.textContent = "Reinvestition zeigt Wirkung";
    statusValueEl.textContent = "Reinvestition aktiv";
    statusSubEl.textContent = "Der simulierte Zinseszinseffekt wird sichtbarer. Wachstum beschleunigt sich.";
    liveTextEl.textContent = "Reinvest läuft";
    phaseTextEl.textContent = "Reinvest → Verstärkung → Struktur zahlt sich aus";
  }else if(month < 24){
    chartHintEl.textContent = "beschleunigtes Wachstum";
    statusValueEl.textContent = "System arbeitet";
    statusSubEl.textContent = "Die visuelle Simulation zeigt jetzt die stärkere Phase des langfristigen Effekts.";
    liveTextEl.textContent = "Wachstum beschleunigt";
    phaseTextEl.textContent = "Effekt → Beschleunigung → klarer Langzeitvorteil";
  }else{
    chartHintEl.textContent = "Langfristiger Effekt";
    statusValueEl.textContent = "Simulation abgeschlossen";
    statusSubEl.textContent = "Kurze Pause — danach startet der Ablauf automatisch wieder von vorne.";
    liveTextEl.textContent = "Reset folgt";
    phaseTextEl.textContent = "Loop beendet → Neustart folgt";
  }
}

function resizeCanvasForDisplay(){
  const ratio = window.devicePixelRatio || 1;
  const rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * ratio;
  canvas.height = rect.height * ratio;
  ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
}

function drawChart(){
  const rect = canvas.getBoundingClientRect();
  const w = rect.width;
  const h = rect.height;

  ctx.clearRect(0, 0, w, h);

  ctx.strokeStyle = "rgba(255,255,255,.06)";
  ctx.lineWidth = 1;

  for(let i=1;i<=4;i++){
    const y = (h / 5) * i;
    ctx.beginPath();
    ctx.moveTo(0, y);
    ctx.lineTo(w, y);
    ctx.stroke();
  }

  if(chartValues.length > 1){
    ctx.beginPath();
    chartValues.forEach((value, i) => {
      const x = (i / (chartValues.length - 1)) * w;
      const norm = (value - startValue) / (targetValue - startValue);
      const y = h - (norm * (h - 20) + 10);
      if(i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.strokeStyle = "rgba(104,166,255,.22)";
    ctx.lineWidth = 10;
    ctx.lineCap = "round";
    ctx.lineJoin = "round";
    ctx.stroke();

    ctx.beginPath();
    chartValues.forEach((value, i) => {
      const x = (i / (chartValues.length - 1)) * w;
      const norm = (value - startValue) / (targetValue - startValue);
      const y = h - (norm * (h - 20) + 10);
      if(i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.strokeStyle = "#68a6ff";
    ctx.lineWidth = 3;
    ctx.lineCap = "round";
    ctx.lineJoin = "round";
    ctx.stroke();

    ctx.beginPath();
    chartValues.forEach((value, i) => {
      const x = (i / (chartValues.length - 1)) * w;
      const norm = (value - startValue) / (targetValue - startValue);
      const y = h - (norm * (h - 20) + 10);
      if(i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.lineTo(w, h);
    ctx.lineTo(0, h);
    ctx.closePath();

    const grad = ctx.createLinearGradient(0, 0, 0, h);
    grad.addColorStop(0, "rgba(47,128,255,.22)");
    grad.addColorStop(1, "rgba(47,128,255,0)");
    ctx.fillStyle = grad;
    ctx.fill();
  }
}

function resetSimulationState(){
  chartValues = [startValue];
  portfolioValueEl.textContent = formatUSD(startValue);
  portfolioGainEl.textContent = "+$0 Gewinn";
  monthLabelEl.textContent = "Monat 1 / 24";
  rewardsValueEl.textContent = "$0";
  reinvestValueEl.textContent = "$0";
  cashflowValueEl.textContent = "$0";
  aprValueEl.textContent = "5.2%";
  feesValueEl.textContent = "$0";
  emissionsValueEl.textContent = "0 AERO";
  loopCounterEl.textContent = "Loop " + loopCount;
  updatePoints(1);
  updateHint(1);
  drawChart();
}

function animateSimulation(){
  const startTime = performance.now();

  function frame(now){
    const elapsed = now - startTime;
    const rawProgress = Math.min(elapsed / animationDuration, 1);
    const eased = easeInOutCubic(rawProgress);

    const currentValue = growthCurve(eased);
    const currentMonth = Math.min(monthsTotal, Math.max(1, Math.ceil(eased * monthsTotal)));

    const totalGain = currentValue - startValue;
    const rewards = totalGain * 0.58;
    const reinvest = totalGain * 0.30;
    const cashflow = totalGain * 0.12;
    const fees = totalGain * 0.09;
    const emissions = totalGain / 38;
    const apr = 5.2 + (Math.sin(eased * Math.PI * 1.2) * 1.2) + (eased * 1.8);

    portfolioValueEl.textContent = formatUSD(currentValue);
    portfolioGainEl.textContent = "+" + formatUSD(totalGain).replace("$","$") + " Gewinn";
    monthLabelEl.textContent = "Monat " + currentMonth + " / " + monthsTotal;

    rewardsValueEl.textContent = formatUSD(rewards);
    reinvestValueEl.textContent = formatUSD(reinvest);
    cashflowValueEl.textContent = formatUSD(cashflow);
    feesValueEl.textContent = formatUSD(fees);
    emissionsValueEl.textContent = Math.round(emissions).toLocaleString("en-US") + " AERO";
    aprValueEl.textContent = apr.toFixed(1) + "%";
    loopCounterEl.textContent = "Loop " + loopCount;

    updatePoints(currentMonth);
    updateHint(currentMonth);

    const expectedLength = currentMonth;
    while(chartValues.length < expectedLength){
      const p = chartValues.length / (monthsTotal - 1 || 1);
      const val = growthCurve(p);
      chartValues.push(val);
    }

    if(chartValues.length > 0){
      chartValues[chartValues.length - 1] = currentValue;
    }else{
      chartValues.push(currentValue);
    }

    drawChart();

    if(rawProgress < 1){
      animationFrameId = requestAnimationFrame(frame);
    }else{
      loopTimeout = setTimeout(() => smoothRestart(), restartDelay);
    }
  }

  animationFrameId = requestAnimationFrame(frame);
}

function smoothRestart(){
  let fade = 1;
  const dashboard = document.querySelector(".dashboard");
  const hero = document.querySelector(".hero");

  function step(){
    fade -= 0.06;
    dashboard.style.opacity = Math.max(fade, 0.35);
    hero.style.opacity = Math.max(fade + 0.15, 0.5);

    if(fade > 0.4){
      requestAnimationFrame(step);
    }else{
      loopCount++;
      resetSimulationState();
      dashboard.style.opacity = 1;
      hero.style.opacity = 1;
      setTimeout(() => animateSimulation(), 350);
    }
  }

  requestAnimationFrame(step);
}

window.addEventListener("resize", () => {
  resizeCanvasForDisplay();
  drawChart();
});

window.addEventListener("load", () => {
  resizeCanvasForDisplay();
  resetSimulationState();
  setTimeout(() => animateSimulation(), 500);
});
</script>
